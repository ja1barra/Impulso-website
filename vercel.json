{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/servicios", "destination": "/servicios.html" },
    { "source": "/blog", "destination": "/blog.html" }
  ],
  "redirects": [
    { "source": "/servicios/", "destination": "/servicios", "permanent": true },
    { "source": "/blog/", "destination": "/blog", "permanent": true }
  ]
}
